<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — white "O" lettermark centred in the safe zone.
  The viewBox is 108×108dp (full adaptive icon canvas); the safe zone is the
  inner 72×72dp centred region. Artwork is sized to stay inside the safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- "O" ring: outer radius 28, inner radius 18, centred at 54,54 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M54,26
          A28,28 0 1 1 53.999,26
          Z
          M54,36
          A18,18 0 1 0 54.001,36
          Z"
        android:fillType="evenOdd" />
</vector>
